.vscode/
.idea/

# Jupyter
.ipynb_checkpoints/
*.ipynb

# Claude Code context 
CLAUDE.md

# Databases & Cache
*.db
*.sqlite
*.db-shm
*.db-wal
.cache/
data/*.db
